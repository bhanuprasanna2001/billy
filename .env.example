# Postgres (exposed on host:5433, internal 5432)
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_DB=credit_domino
POSTGRES_USER=dev
POSTGRES_PASSWORD=dev

# Neo4j (browser :7474, bolt :7687)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=devpassword123

# ClickHouse (HTTP :8123, native :9000)
CLICKHOUSE_HOST=localhost
CLICKHOUSE_PORT=8123
CLICKHOUSE_DB=credit_domino
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=

# MLflow (tracking UI :5001)
MLFLOW_TRACKING_URI=http://localhost:5001

# Airflow (webserver :8080)
_AIRFLOW_WWW_USER_USERNAME=your_custom_username
_AIRFLOW_WWW_USER_PASSWORD=your_secure_password